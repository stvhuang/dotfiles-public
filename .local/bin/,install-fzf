#!/usr/bin/env sh

set -eu

VERSION="0.72.0"

UNAME_S="$(uname -s)"
case "${UNAME_S}" in
Darwin) SYSNAME="darwin" ;;
# Linux) SYSNAME="linux" ;;
*)
  printf "[FZF] unsupported sysname: %s\n" "${UNAME_S}" >&2
  exit 1
  ;;
esac

UNAME_M="$(uname -m)"
case "${UNAME_M}" in
arm64) MACHINE="arm64" ;;
# aarch64) MACHINE="arm64" ;;
# x86_64 | x64) MACHINE="amd64" ;;
*)
  printf "Unsupported machine: %s\n" "${UNAME_M}" >&2
  exit 1
  ;;
esac

printf "Detected sysname/machine: %s/%s\n" "${SYSNAME}" "${MACHINE}"

URL="https://github.com/junegunn/fzf/releases/download/v${VERSION}/fzf-${VERSION}-${SYSNAME}_${MACHINE}.tar.gz"
BIN_DIR="${HOME}/.local/bin"
TMP_TAR="$(mktemp -t fzf.XXXXXX).tar.gz"

mkdir -p "${BIN_DIR}"

cleanup() { rm -f "${TMP_TAR}"; }
trap cleanup EXIT

printf "Downloading %s\n" "${URL}"
curl -fLsS -o "${TMP_TAR}" "${URL}"

printf "Extracting to %s\n" "${BIN_DIR}"
tar -xzf "${TMP_TAR}" -C "${BIN_DIR}"

chmod +x "${BIN_DIR}/fzf"
printf "Installed fzf to %s/fzf\n" "${BIN_DIR}"
